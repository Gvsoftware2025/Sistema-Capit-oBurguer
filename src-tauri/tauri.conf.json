{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Capitao Burguer",
  "version": "1.0.0",
  "identifier": "com.capitaoburguer.sistema",
  "build": {
    "devUrl": "http://localhost:3000",
    "frontendDist": "https://sistema-capit-o-burguer.vercel.app"
  },
  "app": {
    "windows": [
      {
        "title": "Capitao Burguer - Sistema de Gestao",
        "width": 1280,
        "height": 800,
        "minWidth": 800,
        "minHeight": 600,
        "resizable": true,
        "fullscreen": false,
        "center": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": ["nsis"],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "windows": {
      "nsis": {
        "languages": ["PortugueseBR"],
        "displayLanguageSelector": false,
        "installMode": "currentUser",
        "installerIcon": "icons/icon.ico"
      }
    }
  }
}
